# ============================================================
#  BACKEND — variáveis de ambiente (produção: Railway)
#  Copie estes nomes nas "Variables" do serviço no Railway.
#  NÃO comite o arquivo .env real (já está no .gitignore).
# ============================================================

# ─── Banco de dados (Supabase) ─────────────────────────────
# Use a string do "Session pooler" do Supabase (IPv4), não a conexão direta.
# Supabase → Project Settings → Database → Connection string → "Session pooler".
# Formato: postgresql://postgres.<ref>:<SENHA>@aws-1-<regiao>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# ─── App ───────────────────────────────────────────────────
# Segredo do login do painel. Gere um forte (ex: openssl rand -hex 32).
JWT_SECRET=
# URL pública do frontend na Vercel (usado no CORS). Ex: https://clinica.vercel.app
FRONTEND_URL=
# O Railway define PORT automaticamente — não precisa preencher.
# PORT=3000

# ─── Anthropic Claude API ──────────────────────────────────
# Vazio = modo MOCK (heurística, sem custo). Preencha para respostas reais.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_CONTEXT_MESSAGES=10

# ─── Meta WhatsApp Cloud API ───────────────────────────────
# Vazio = dry-run (não envia, só loga). Preencha quando o número estiver no Meta.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Token que VOCÊ inventa e repete no painel da Meta ao configurar o webhook.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# App Secret da Meta (valida a assinatura do webhook). Vazio = pula a checagem.
WHATSAPP_APP_SECRET=

# ─── Fila / Redis ──────────────────────────────────────────
# false = fila em memória (ok para 1 instância). true = usar Redis (Upstash).
REDIS_ENABLED=false
# REDIS_URL=  # só se REDIS_ENABLED=true

# ─── Regras de negócio ─────────────────────────────────────
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
TIMEZONE=America/Sao_Paulo
