# ─── Meta WhatsApp Cloud API ───────────────────────────────
# Vazio = dry-run (não envia, só loga).
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# ─── Anthropic Claude API ──────────────────────────────────
# Vazio = modo MOCK (heurística, sem custo).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_CONTEXT_MESSAGES=10

# ─── Banco de dados / Cache ────────────────────────────────
# Credenciais usadas pelo container do Postgres (docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=clinica_bot
# String de conexão usada pelo backend.
# Em docker-compose o host é "postgres"; rodando local use "localhost".
DATABASE_URL=postgresql://user:password@postgres:5432/clinica_bot
REDIS_URL=redis://redis:6379
# false = fila em memória (dev). true = usar Redis/BullMQ (Upstash/produção).
REDIS_ENABLED=false

# ─── App ───────────────────────────────────────────────────
PORT=3000
JWT_SECRET=
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Horário comercial (usado nas regras de negócio do bot)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
TIMEZONE=America/Sao_Paulo
